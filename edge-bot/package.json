{
  "name": "@perry/edge-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-knowledge GitHub Action that opens issues when a dependency's ToS changes.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "all": "npm run build && npm run package",
    "local": "node dist/index.js"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.4.0"
  }
}
